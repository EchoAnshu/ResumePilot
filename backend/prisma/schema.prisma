generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Resume {
  id           String   @id @default(uuid())
  originalName String
  filename     String   @unique
  mimeType     String
  size         Int
  parsedData   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
}
